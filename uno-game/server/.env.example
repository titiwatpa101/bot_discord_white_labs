# Discord OAuth2 (ใช้ App เดิมกับ Bot ได้เลย — แค่เพิ่ม Redirect URI)
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback

# Session (เปลี่ยนเป็น random string ยาวๆ)
SESSION_SECRET=change-this-to-something-random

# URLs
CLIENT_URL=http://localhost:5173
PORT=3001

# Shared secret กับ Discord Bot
BOT_API_KEY=change-this-to-something-random
